NODE_ENV=production
APP_BASE_URL=https://nft-data-platform.example.com
MONGODB_DATABASE=nft_data_platform
# Use URL-safe credentials here because docker-compose.coolify.yml builds connection URIs from them.
# Safe characters: letters, numbers, -, _, .
MONGODB_ROOT_USERNAME=root
MONGODB_ROOT_PASSWORD=replace-with-a-strong-mongo-root-password
MONGODB_APP_USERNAME=nft_app
MONGODB_APP_PASSWORD=replace-with-a-strong-mongo-app-password
REDIS_PASSWORD=replace-with-a-strong-redis-password

# Bootstrap API client used by the operator UI and signed demo requests.
API_CLIENT_SECRET_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
API_BOOTSTRAP_CLIENT_ID=coolify-operator
API_BOOTSTRAP_KEY=replace-with-a-long-random-key
API_BOOTSTRAP_SECRET=replace-with-a-long-random-secret
API_BOOTSTRAP_SCOPES=collections:read,tokens:read,owners:read,search:read,refresh:token,refresh:collection,refresh:media,reindex:write,admin:read
API_BOOTSTRAP_RATE_LIMIT_PER_MINUTE=300
API_BOOTSTRAP_ALLOWED_IPS=
AUTH_MAX_TIMESTAMP_SKEW_SEC=300

# RPC providers used by the worker.
RPC_MAINNET_URL=https://mainnet.example-rpc.invalid
RPC_SEPOLIA_URL=https://sepolia.example-rpc.invalid

# Internal S3-compatible media storage.
# Keep S3_PUBLIC_BASE_URL on the internal MinIO URL.
# The web app now reads those objects through S3 credentials instead of anonymous bucket access.
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=replace-with-minio-access-key
S3_SECRET_KEY=replace-with-minio-secret-key
S3_BUCKET=nft-media
S3_PUBLIC_BASE_URL=http://minio:9000/nft-media
MINIO_ROOT_USER=replace-with-minio-access-key
MINIO_ROOT_PASSWORD=replace-with-minio-secret-key

MEDIA_MAX_VIDEO_BYTES=25000000
CHAIN_INDEXING_ENABLED=false
CHAIN_INDEXING_POLL_INTERVAL_MS=30000
CHAIN_INDEXING_BATCH_SIZE=10
CHAIN_INDEXING_MAX_BLOCK_RANGE=2000
CHAIN_INDEXING_COLLECTION_ALLOWLIST=
