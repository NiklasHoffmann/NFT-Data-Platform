NODE_ENV=development
APP_BASE_URL=http://localhost:3000
MONGODB_URI=mongodb://localhost:27017
MONGODB_DATABASE=nft_data_platform
REDIS_URL=redis://localhost:6379
API_CLIENT_SECRET_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=nft-media
S3_PUBLIC_BASE_URL=http://localhost:9000/nft-media
MEDIA_MAX_VIDEO_BYTES=25000000
CHAIN_INDEXING_ENABLED=false
CHAIN_INDEXING_POLL_INTERVAL_MS=30000
CHAIN_INDEXING_BATCH_SIZE=10
CHAIN_INDEXING_MAX_BLOCK_RANGE=2000
CHAIN_INDEXING_COLLECTION_ALLOWLIST=
RPC_MAINNET_URL=https://mainnet.example-rpc.invalid
RPC_MAINNET_WSS_URL=wss://mainnet.example-rpc.invalid
RPC_SEPOLIA_URL=https://sepolia.example-rpc.invalid
RPC_SEPOLIA_WSS_URL=wss://sepolia.example-rpc.invalid
API_BOOTSTRAP_CLIENT_ID=local-operator
API_BOOTSTRAP_KEY=nft_local_bootstrap_key
API_BOOTSTRAP_SECRET=nft_local_bootstrap_secret
API_BOOTSTRAP_SCOPES=collections:read,tokens:read,owners:read,search:read,refresh:token,refresh:collection,refresh:media,reindex:write,admin:read
API_BOOTSTRAP_RATE_LIMIT_PER_MINUTE=300
API_BOOTSTRAP_ALLOWED_IPS=
AUTH_MAX_TIMESTAMP_SKEW_SEC=300
